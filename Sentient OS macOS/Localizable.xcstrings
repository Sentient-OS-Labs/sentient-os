        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentient обновляется автоматически. Когда готова новая версия, Sentient просит обновиться перед продолжением — вы всегда на самой свежей и безопасной версии."
          }
        }
      }
    },
    "Sentient needs a few permissions to read your life on this Mac." : {
      "localizations" : {
