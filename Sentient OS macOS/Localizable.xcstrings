          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sentient никогда не собирает ваши персональные данные и не анализирует их с помощью ИИ. Конфиденциальность — главный принцип всего Sentient, а весь стек всегда останется открытым."
          }
        }
      }
